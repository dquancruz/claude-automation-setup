# ============================================================================
# ENVIRONMENT TEMPLATE
# ============================================================================
# Copy this file to .env.local in your repo and fill in the real values.
# NEVER commit .env.local — it contains secrets.
#
#   cp .env.example .env.local
#
# ============================================================================

# ----------------------------------------------------------------------------
# JIRA
# ----------------------------------------------------------------------------
# Get your API token at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_HOST=yourcompany.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJ

# ----------------------------------------------------------------------------
# GITHUB
# ----------------------------------------------------------------------------
# Create a token at: https://github.com/settings/tokens
# Required scopes: repo, workflow
GITHUB_TOKEN=
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo

# ----------------------------------------------------------------------------
# GIT (commit author identity for automated commits)
# ----------------------------------------------------------------------------
GIT_AUTHOR_NAME=Your Name
GIT_AUTHOR_EMAIL=your-email@company.com

# ----------------------------------------------------------------------------
# GPG (optional — for signed commits)
# ----------------------------------------------------------------------------
# Get your key ID with: gpg --list-secret-keys --keyid-format LONG
GPG_KEY_ID=
